# macOS
.DS_Store
.AppleDouble
.LSOverride
# Finder custom-icon files ("Icon\r"). A bare "Icon" also matches the icon/
# source directory (macOS git ignores case), which kept AppIcon.icns out of
# git and broke the release build.
Icon?
._*

